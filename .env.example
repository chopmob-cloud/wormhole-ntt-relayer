# ── Algo → Base (cast_relayer.py) ─────────────────────────────────────────────
RPCURL=https://mainnet.base.org
PRIVATEKEY=                        # 64 hex chars, no 0x prefix
BASE_TRANSCEIVER=                  # Base WormholeTransceiver contract (0x-prefixed)
ALGO_EMITTER_ADDRESS=              # Algorand NTT emitter address (hex, no 0x, 32 bytes)

# ── Base → Algorand (relay_service.py / base-relayer.py / ntt_execute.py) ─────
ALGO_MNEMONIC=                     # 25-word Algorand mnemonic
ALGOD_URL=https://mainnet-api.4160.nodely.dev
ALGOD_TOKEN=
BASE_EMITTER=                      # Base WormholeTransceiver emitter (32-byte hex, no 0x)
# BASE_CHAIN=30                    # Wormhole chain ID for the source chain (default 30 = Base)

# ── Algorand App IDs ──────────────────────────────────────────────────────────
WT_APP_ID=                         # WormholeTransceiver app ID
NTT_MGR_APP_ID=                    # NTT Manager app ID
TRANSCEIVER_MGR_APP_ID=            # TransceiverManager app ID
NTT_TOKEN_ASSET_ID=                # Token ASA ID

# ── Optional overrides ────────────────────────────────────────────────────────
# WORMHOLE_CORE_APP_ID=842125965   # Wormhole Core (public constant, rarely changes)
# CAST_BIN=/home/ubuntu/.foundry/bin/cast
